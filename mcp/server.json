{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "com.octoparse/mcp",
  "title": "Octoparse MCP Server",
  "description": "Octoparse web scraping MCP server. Supports international (mcp.octoparse.com) and China (mcp.bazhuayu.com) regions.",
  "version": "1.0.0",
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://{host}",
      "variables": {
        "host": {
          "description": "MCP server host by region",
          "isRequired": true,
          "choices": ["mcp.octoparse.com", "mcp.bazhuayu.com"],
          "default": "mcp.octoparse.com"
        }
      }
    }
  ]
}
